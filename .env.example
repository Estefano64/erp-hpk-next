# Conexión a Postgres (provista por Railway al provisionar el plugin)
# En local apunta a tu Postgres dev. En Railway viene automáticamente.
DATABASE_URL="postgresql://user:password@host:5432/db"

# NextAuth — secreto para firmar JWTs.
# Generar con: openssl rand -base64 32
# IMPORTANTE: usar valores DISTINTOS por entorno (local/staging/prod).
NEXTAUTH_SECRET="genera-uno-nuevo-con-openssl-rand-base64-32"

# URL pública de la app. En Railway: https://<service>.up.railway.app
# En local: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
