// ── Almacén físico HP&K — Zonas y Posiciones ─────────────────────────
// Hoy el almacén está dividido en 3 zonas (Herramientas/Suministros, OTs,
// Stock). Cada zona tiene celdas tipo A1, A2, B1... donde se ubican los
// repuestos físicamente. Sirve para:
//   - Trazabilidad al consumir de almacén (a dónde se entregó el material).
//   - Auto-ubicar nuevos items de OC en la misma celda que otros reqs ya
//     ubicados de la misma OT.
model AlmacenZona {
  id          Int                @id @default(autoincrement())
  codigo      String             @unique @db.VarChar(20)
  nombre      String             @db.VarChar(100)
  descripcion String?            @db.VarChar(300)
  orden       Int                @default(0)
  activo      Boolean            @default(true)
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  posiciones  AlmacenPosicion[]
  repuestos   OTRepuesto[]

  @@map("almacen_zona")
}

model AlmacenPosicion {
  id          Int          @id @default(autoincrement())
  zona_id     Int
  codigo      String       @db.VarChar(20)
  nombre      String?      @db.VarChar(100)
  activo      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  zona        AlmacenZona  @relation(fields: [zona_id], references: [id], onDelete: Cascade)
  repuestos   OTRepuesto[]

  // El mismo código (ej. "A1") puede repetirse en distintas zonas — es
  // único solo dentro de su zona.
  @@unique([zona_id, codigo])
  @@index([zona_id])
  @@map("almacen_posicion")
}

model MaterialNoCatalogado {
  id               Int                       @id @default(autoincrement())
  codigo           String                    @unique @db.VarChar(50)
  descripcion      String                    @db.VarChar(300)
  unidad_medida    String                    @default("UNIDAD") @db.VarChar(20)
  stock_actual     Decimal                   @default(0) @db.Decimal(12, 2)
  ubicacion_codigo String?                   @db.VarChar(10)
  observaciones    String?
  activo           Boolean                   @default(true)
  created_at       DateTime                  @default(now())
  updated_at       DateTime                  @updatedAt
  ubicacion        Ubicacion?                @relation(fields: [ubicacion_codigo], references: [codigo])
  movimientos      MovimientoNoCatalogado[]

  @@map("material_no_catalogado")
}

model MovimientoNoCatalogado {
  id                   Int                      @id @default(autoincrement())
  material_no_cat_id   Int
  tipo_movimiento      TipoMovimientoInventario
  cantidad             Decimal                  @db.Decimal(12, 2)
  motivo               String?                  @db.VarChar(300)
  documento_referencia String?                  @db.VarChar(100)
  usuario              String                   @db.VarChar(100)
  fecha_movimiento     DateTime                 @default(now())
  created_at           DateTime                 @default(now())
  material             MaterialNoCatalogado     @relation(fields: [material_no_cat_id], references: [id], onDelete: Cascade)

  @@index([material_no_cat_id])
  @@index([fecha_movimiento])
  @@map("movimiento_no_catalogado")
}

