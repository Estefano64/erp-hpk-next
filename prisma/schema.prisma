generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Planta {
  planta_id  Int        @id @default(autoincrement())
  codigo     String     @unique @db.VarChar(10)
  nombre     String     @db.VarChar(100)
  direccion  String?    @db.VarChar(200)
  activo     Boolean    @default(true)
  areas      Area[]
  equipos    Equipo[]
  materiales Material[]

  @@map("planta")
}

model Usuario {
  id             Int      @id @default(autoincrement())
  codigoEmpleado String   @unique @map("codigo_empleado") @db.VarChar(20)
  email          String?  @unique @db.VarChar(100)
  dni            String?  @unique @db.VarChar(20)
  password       String   @db.VarChar(255)
  nombre         String   @db.VarChar(100)
  rol            String   @default("viewer") @db.VarChar(20)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("usuarios")
}

model Area {
  area_id       Int          @id @default(autoincrement())
  codigo        String       @unique @db.VarChar(10)
  nombre        String       @db.VarChar(100)
  planta_codigo String?      @db.VarChar(10)
  activo        Boolean      @default(true)
  planta        Planta?      @relation(fields: [planta_codigo], references: [codigo])
  equipos       Equipo[]
  estrategias   Estrategia[]
  materiales    Material[]
  sub_areas     SubArea[]

  @@map("area")
}

model SubArea {
  sub_area_id Int      @id @default(autoincrement())
  codigo      String   @unique @db.VarChar(10)
  nombre      String   @db.VarChar(100)
  area_codigo String   @db.VarChar(10)
  activo      Boolean  @default(true)
  equipos     Equipo[]
  area        Area     @relation(fields: [area_codigo], references: [codigo])

  @@map("sub_area")
}

model UnidadMedida {
  unidad_medida_id Int          @id @default(autoincrement())
  codigo           String       @unique @db.VarChar(10)
  nombre           String       @db.VarChar(100)
  abreviatura      String?      @db.VarChar(20)
  activo           Boolean      @default(true)
  equipos          Equipo[]
  estrategias      Estrategia[]
  materiales       Material[]

  @@map("unidad_medida")
}

model Moneda {
  moneda_id          Int                @id @default(autoincrement())
  codigo             String             @unique @db.VarChar(10)
  nombre             String             @db.VarChar(100)
  simbolo            String?            @db.VarChar(10)
  activo             Boolean            @default(true)
  codigos_reparacion CodigoReparacion[]
  equipos            Equipo[]
  materiales         Material[]
  compras            Compra[]

  @@map("moneda")
}

model Fabricante {
  fabricante_id      Int                @id @default(autoincrement())
  codigo             String             @unique @db.VarChar(20)
  nombre             String             @db.VarChar(200)
  pais               String?            @db.VarChar(100)
  activo             Boolean            @default(true)
  codigos_reparacion CodigoReparacion[]
  equipos            Equipo[]
  materiales         Material[]
  ordenes_trabajo    OrdenTrabajo[]
  tareas             Tarea[]

  @@map("fabricante")
}

model Categoria {
  categoria_id Int        @id @default(autoincrement())
  codigo       String     @unique @db.VarChar(10)
  nombre       String     @db.VarChar(100)
  activo       Boolean    @default(true)
  materiales   Material[]

  @@map("categoria")
}

model Clasificacion {
  clasificacion_id Int        @id @default(autoincrement())
  codigo           String     @unique @db.VarChar(10)
  nombre           String     @db.VarChar(100)
  activo           Boolean    @default(true)
  materiales       Material[]

  @@map("clasificacion")
}

model StatusEquipo {
  status_equipo_id Int      @id @default(autoincrement())
  codigo           String   @unique @db.VarChar(10)
  nombre           String   @db.VarChar(100)
  activo           Boolean  @default(true)
  equipos          Equipo[]

  @@map("status_equipo")
}

model TipoEquipo {
  tipo_equipo_id Int      @id @default(autoincrement())
  codigo         String   @unique @db.VarChar(10)
  nombre         String   @db.VarChar(100)
  activo         Boolean  @default(true)
  equipos        Equipo[]

  @@map("tipo_equipo")
}

model Criticidad {
  criticidad_id Int      @id @default(autoincrement())
  codigo        String   @unique @db.VarChar(10)
  nombre        String   @db.VarChar(100)
  nivel         Int?
  activo        Boolean  @default(true)
  equipos       Equipo[]

  @@map("criticidad")
}

model Ubicacion {
  ubicacion_id Int      @id @default(autoincrement())
  codigo       String   @unique @db.VarChar(10)
  nombre       String   @db.VarChar(100)
  descripcion  String?  @db.VarChar(200)
  activo       Boolean? @default(true)
  equipos      Equipo[]
  compras      Compra[]

  @@map("ubicacion")
}

model StatusEstrategia {
  status_estrategia_id Int          @id @default(autoincrement())
  codigo               String       @unique @db.VarChar(10)
  nombre               String       @db.VarChar(100)
  activo               Boolean      @default(true)
  estrategias          Estrategia[]

  @@map("status_estrategia")
}

model TipoEstrategia {
  tipo_estrategia_id Int          @id @default(autoincrement())
  codigo             String       @unique @db.VarChar(10)
  nombre             String       @db.VarChar(100)
  activo             Boolean      @default(true)
  estrategias        Estrategia[]

  @@map("tipo_estrategia")
}

model StatusRequerimiento {
  status_requerimiento_id Int          @id @default(autoincrement())
  codigo                  String       @unique @db.VarChar(20)
  nombre                  String       @db.VarChar(100)
  orden                   Int?
  activo                  Boolean      @default(true)
  created_at              DateTime     @default(now())
  updated_at              DateTime     @default(now()) @updatedAt
  ot_repuestos            OTRepuesto[]

  @@map("status_requerimiento")
}

model StatusCotizacion {
  status_cotizacion_id Int          @id @default(autoincrement())
  codigo               String       @unique @db.VarChar(20)
  nombre               String       @db.VarChar(100)
  orden                Int?
  activo               Boolean      @default(true)
  created_at           DateTime     @default(now())
  updated_at           DateTime     @default(now()) @updatedAt
  ot_repuestos         OTRepuesto[]

  @@map("status_cotizacion")
}

model StatusOC {
  status_oc_id    Int             @id @default(autoincrement())
  codigo          String          @unique @db.VarChar(20)
  nombre          String          @db.VarChar(100)
  orden           Int?
  activo          Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @default(now()) @updatedAt
  ot_repuestos    OTRepuesto[]
  compras         Compra[]
  compras_detalle CompraDetalle[]

  @@map("status_oc")
}

model StatusTarea {
  status_tarea_id Int               @id @default(autoincrement())
  codigo          String            @unique @db.VarChar(20)
  nombre          String            @db.VarChar(100)
  color           String?           @db.VarChar(20)
  orden           Int?
  activo          Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now()) @updatedAt
  planificaciones PlanificacionOT[]

  @@map("status_tarea")
}

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA
  AJUSTE
}

model TipoTarea {
  tipo_tarea_id Int     @id @default(autoincrement())
  codigo        String  @unique @db.VarChar(10)
  nombre        String  @db.VarChar(100)
  activo        Boolean @default(true)
  tareas        Tarea[]

  @@map("tipo_tarea")
}

model TipoCodRep {
  tipo_cod_rep_id    Int                @id @default(autoincrement())
  codigo             String             @unique @db.VarChar(10)
  nombre             String             @db.VarChar(100)
  activo             Boolean            @default(true)
  codigos_reparacion CodigoReparacion[]

  @@map("tipo_cod_rep")
}

model CategoriaCodRep {
  categoria_cod_rep_id Int                @id @default(autoincrement())
  codigo               String             @unique @db.VarChar(10)
  nombre               String             @db.VarChar(100)
  activo               Boolean            @default(true)
  codigos_reparacion   CodigoReparacion[]

  @@map("categoria_cod_rep")
}

model FlotaEquipo {
  flota_equipo_id    Int                @id @default(autoincrement())
  codigo             String             @unique @db.VarChar(20)
  nombre             String             @db.VarChar(100)
  activo             Boolean            @default(true)
  codigos_reparacion CodigoReparacion[]

  @@map("flota_equipo")
}

model Posicion {
  posicion_id        Int                @id @default(autoincrement())
  codigo             String             @unique @db.VarChar(10)
  nombre             String             @db.VarChar(100)
  activo             Boolean            @default(true)
  codigos_reparacion CodigoReparacion[]

  @@map("posicion")
}

model Componente {
  componente_id       Int                   @id @default(autoincrement())
  codigo              String                @unique @db.VarChar(30)
  nombre              String                @db.VarChar(100)
  activo              Boolean               @default(true)
  created_at          DateTime              @default(now())
  updated_at          DateTime              @default(now()) @updatedAt
  operaciones         OperacionReparacion[]
  operaciones_cod_rep OperacionCodRep[]

  @@map("componente")
}

model ModeloEvaluacion {
  modelo_evaluacion_id Int                @id @default(autoincrement())
  codigo               String             @unique @db.VarChar(10)
  nombre               String             @db.VarChar(200)
  activo               Boolean            @default(true)
  created_at           DateTime           @default(now())
  updated_at           DateTime           @default(now()) @updatedAt
  codigos_reparacion   CodigoReparacion[]

  @@map("modelo_evaluacion")
}

model OperacionReparacion {
  operacion_reparacion_id Int               @id @default(autoincrement())
  codigo                  String            @unique @db.VarChar(20)
  nombre                  String            @db.VarChar(200)
  componente_codigo       String?           @db.VarChar(30)
  clasificacion           String            @default("STD") @db.VarChar(10)
  activo                  Boolean           @default(true)
  created_at              DateTime          @default(now())
  updated_at              DateTime          @default(now()) @updatedAt
  componente              Componente?       @relation(fields: [componente_codigo], references: [codigo])
  operaciones_cod_rep     OperacionCodRep[]

  @@index([componente_codigo, clasificacion])
  @@map("operacion_reparacion")
}

// Plantilla: operaciones estándar de una reparación por CodRep.
// Al crear una OT con CodRep=X, se copian estas filas a PlanificacionOT.
// Fuente: Excel `5.1 Encabezados.xlsx` (1856 filas).
model OperacionCodRep {
  operacion_cod_rep_id        Int                  @id @default(autoincrement())
  cod_rep_codigo              String               @db.VarChar(50)
  componente_codigo           String               @db.VarChar(30)
  operacion_reparacion_codigo String?              @db.VarChar(20)
  trabajo                     String               @db.VarChar(200)
  qty                         Int                  @default(1)
  horas                       Decimal?             @db.Decimal(6, 2)
  hh                          Decimal?             @db.Decimal(6, 2)
  orden                       Int                  @default(0)
  activo                      Boolean              @default(true)
  created_at                  DateTime             @default(now())
  updated_at                  DateTime             @default(now()) @updatedAt
  codigo_reparacion           CodigoReparacion     @relation(fields: [cod_rep_codigo], references: [codigo], onDelete: Cascade)
  componente                  Componente           @relation(fields: [componente_codigo], references: [codigo])
  operacion_reparacion        OperacionReparacion? @relation(fields: [operacion_reparacion_codigo], references: [codigo])
  planificaciones             PlanificacionOT[]

  @@index([cod_rep_codigo])
  @@index([componente_codigo])
  @@map("operacion_cod_rep")
}

model Cliente {
  cliente_id         Int            @id @default(autoincrement())
  codigo             String         @unique @db.VarChar(10)
  razon_social       String         @db.VarChar(200)
  nombre_comercial   String?        @db.VarChar(200)
  ruc                String?        @db.VarChar(20)
  direccion          String?        @db.VarChar(300)
  telefono           String?        @db.VarChar(50)
  email              String?        @db.VarChar(100)
  contacto_principal String?        @db.VarChar(200)
  activo             Boolean        @default(true)
  usuario_crea       String?        @db.VarChar(100)
  usuario_actualiza  String?        @db.VarChar(100)
  created_at         DateTime       @default(now())
  updated_at         DateTime       @default(now()) @updatedAt
  contratos          Contrato[]
  ordenes_trabajo    OrdenTrabajo[]

  @@map("cliente")
}

