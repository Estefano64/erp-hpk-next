  informe_archivo          String?      @db.VarChar(500)
  informe_nombre           String?      @db.VarChar(300)
  informe_fecha_subida     DateTime?
  estado                   String       @default("BORRADOR") @db.VarChar(25)
  revisado_por             String?      @db.VarChar(150)
  fecha_revision           DateTime?
  comentarios_revision     String?
  solicitado_revision_por  String?      @db.VarChar(150)
  fecha_solicitud_revision DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  orden_trabajo            OrdenTrabajo @relation(fields: [ot_id], references: [id], onDelete: Cascade)

  @@index([ot_id])
  @@index([estado])
  @@map("evaluaciones_tecnicas")
}
