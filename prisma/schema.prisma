// OTRepuesto admite items tanto de OT externa como de OT interna. Uno y solo
// uno de los dos FK (ot_id / orden_trabajo_interna_id) debe estar seteado.
// La aplicación valida el XOR (no hay constraint a nivel BD por simplicidad).
model OTRepuesto {
  id                          Int                  @id @default(autoincrement())
  ot_id                       Int?
  orden_trabajo_interna_id    Int?
  material_id                 Int?
  material_codigo             String?              @db.VarChar(20)
  nro_req                     String?              @db.VarChar(50)
  item_req                    Int?
  tipo_codigo                 String?              @db.VarChar(10)
  cantidad                    Decimal              @db.Decimal(10, 2)
  cantidad_en_transito        Decimal?             @default(0) @db.Decimal(10, 2)
  cantidad_recibida           Decimal?             @default(0) @db.Decimal(10, 2)
  descripcion                 String?
  texto                       String?
  fabricante_codigo           String?              @db.VarChar(50)
  unidad_medida               String?              @default("UNIDAD") @db.VarChar(20)
  fecha_solicitud             DateTime             @default(now()) @db.Date
  fecha_requerida             DateTime?            @db.Date
  status_requerimiento_codigo String?              @db.VarChar(20)
  status_cotizacion_codigo    String?              @db.VarChar(20)
  status_oc_codigo            String?              @db.VarChar(20)
  po_id                       Int?
  nro_oc                      String?              @db.VarChar(50)
  item_oc                     Int?
  proveedor_id                Int?
  precio_unitario             Decimal?             @db.Decimal(15, 4)
  precio_venta                Decimal?             @db.Decimal(15, 4)
  moneda                      String?              @default("USD") @db.VarChar(10)
  t_req                       Decimal?             @db.Decimal(10, 2)
  t_oc                        Decimal?             @db.Decimal(10, 2)
  t_total                     Decimal?             @db.Decimal(10, 2)
  t_almacenaje                Decimal?             @db.Decimal(10, 2)
  t_armado                    Decimal?             @db.Decimal(10, 2)
  t_fact                      Decimal?             @db.Decimal(10, 2)
  fecha_oc                    DateTime?            @db.Date
  fecha_entrega_esperada      DateTime?            @db.Date
  fecha_entrega_real          DateTime?            @db.Date
  fecha_salida_almacen        DateTime?            @db.Date
  fecha_envio_mina            DateTime?            @db.Date
  fecha_facturacion           DateTime?            @db.Date
  nro_guia                    String?              @db.VarChar(100)
  nro_factura_proveedor       String?              @db.VarChar(100)
  factura_cliente             String?              @db.VarChar(100)
  gr_mina                     String?              @db.VarChar(100)
  evaluador                   String?              @db.VarChar(100)
  es_adicional                Boolean?             @default(false)
  ubicacion                   String?              @db.VarChar(50)
  // Almacén físico HP&K donde se guardó / entregó el item. Se setea cuando
  // se consume de almacén o cuando se recibe contra OC. Permite trazabilidad
  // y auto-asignación de ubicación a nuevos items de la misma OT.
  almacen_zona_id             Int?
  almacen_posicion_id         Int?
  observaciones               String?
  usuario_solicita            String               @db.VarChar(100)
  usuario_envia               String?              @db.VarChar(100)
  fecha_envio_aprobacion      DateTime?            @db.Date
  usuario_aprueba             String?              @db.VarChar(100)
  fecha_aprobacion            DateTime?            @db.Date
  // Comentario / recomendación que dejó el aprobador. Opcional. Se setea
  // en el momento de aprobar (single o lote). Si después se anula y se
  // vuelve a aprobar, este campo se reescribe con el nuevo comentario.
  // 500 caracteres alcanzan para notas breves sin ahogar la UI ni el log.
  comentario_aprobacion       String?              @db.VarChar(500)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  material                    Material?            @relation(fields: [material_id], references: [material_id], onDelete: Restrict)
  orden_trabajo               OrdenTrabajo?        @relation(fields: [ot_id], references: [id], onDelete: Cascade)
  orden_trabajo_interna       OrdenTrabajoInterna? @relation(fields: [orden_trabajo_interna_id], references: [id], onDelete: Cascade)
  compra                      Compra?              @relation(fields: [po_id], references: [id])
  proveedor                   Proveedor?           @relation(fields: [proveedor_id], references: [id])
  status_requerimiento        StatusRequerimiento? @relation(fields: [status_requerimiento_codigo], references: [codigo])
  status_cotizacion           StatusCotizacion?    @relation(fields: [status_cotizacion_codigo], references: [codigo])
  status_oc                   StatusOC?            @relation(fields: [status_oc_codigo], references: [codigo])
  adjuntos                    OTRepuestoAdjunto[]
  almacen_zona                AlmacenZona?         @relation(fields: [almacen_zona_id], references: [id])
  almacen_posicion            AlmacenPosicion?     @relation(fields: [almacen_posicion_id], references: [id])

  @@index([ot_id])
  @@index([orden_trabajo_interna_id])
  @@index([nro_req])
  @@index([status_requerimiento_codigo])
  @@index([status_oc_codigo])
  @@index([po_id])
  @@index([nro_oc])
  @@index([almacen_zona_id])
  @@index([almacen_posicion_id])
  @@map("ot_repuestos")
}

model OTRepuestoAdjunto {
  id              Int        @id @default(autoincrement())
  ot_repuesto_id  Int
  nombre_archivo  String     @db.VarChar(255)
  // Object key en Cloudflare R2. El acceso se hace siempre vía presigned URL.
  r2_key          String     @db.VarChar(500)
  tipo_mime       String     @db.VarChar(100)
  tamano          Int
  usuario_sube    String?    @db.VarChar(100)
  fecha_subida    DateTime   @default(now())
  ot_repuesto     OTRepuesto @relation(fields: [ot_repuesto_id], references: [id], onDelete: Cascade)

  @@index([ot_repuesto_id])
  @@map("ot_repuesto_adjunto")
}

model PlanificacionOT {
  id                   Int                      @id @default(autoincrement())
  // Puede ser null: tareas de APOYO/generales que no pertenecen a una OT.
  // Solo se crean desde Planificación. Si es null, los datos de OT viajan en blanco.
  ot_id                Int?
  operacion_cod_rep_id Int?
  componente           String                   @db.VarChar(30)
  operacion_codigo     String                   @db.VarChar(20)
  descripcion          String                   @db.VarChar(200)
  tipo_reparacion      String?                  @db.VarChar(10)
  orden                Int                      @default(0)
  horas_estimadas      Decimal?                 @db.Decimal(6, 2)
  horas_reales         Decimal?                 @db.Decimal(6, 2)
  fecha_inicio         DateTime?                @db.Timestamp(6)
  fecha_fin            DateTime?                @db.Timestamp(6)
  fecha_inicio_real    DateTime?                @db.Timestamp(6)
  fecha_fin_real       DateTime?                @db.Timestamp(6)
  tecnico              String?                  @db.VarChar(100)
  maquina              String?                  @db.VarChar(50)
  estado               String?                  @default("abierto") @db.VarChar(20)
  // Observaciones de EJECUCIÓN que carga el técnico al pausar/cerrar la tarea.
  observaciones        String?
  // Comentario que deja el planner al crear/editar la tarea; le llega al técnico.
  comentario           String?
  semana_plan          String?                  @db.VarChar(10)
  qty_personal         Int?                     @default(1)
  horas_extras         Boolean?                 @default(false)
  horas_extras_qty     Decimal?                 @db.Decimal(5, 1)
  trabajo_externo      Boolean?                 @default(false)
  // Planificación "publicada" por el planner (deja de ser borrador para el técnico).
  publicado            Boolean                  @default(false)
  // Marca de EMERGENCIA / correctiva. Independiente del `estado` de ejecución:
  // una tarea puede ser correctiva y a la vez estar en_proceso/pausado/realizado.
  es_correctivo        Boolean                  @default(false)
  version              Int                      @default(1)
  created_at           DateTime                 @default(now())
  updated_at           DateTime                 @updatedAt
  orden_trabajo        OrdenTrabajo?            @relation(fields: [ot_id], references: [id], onDelete: Cascade)
  operacion_cod_rep    OperacionCodRep?         @relation(fields: [operacion_cod_rep_id], references: [operacion_cod_rep_id])
  status_tarea         StatusTarea?             @relation(fields: [estado], references: [codigo])
  capturas             PlanificacionOTCaptura[]
  sesiones             PlanificacionOTSesion[]

  @@index([ot_id])
  @@index([operacion_cod_rep_id])
  @@index([estado])
  @@map("planificacion_ot")
}

enum TipoCaptura {
  MEDIDA_NUMERICA
  CHECKLIST_BMN
  FOTO
  TEXTO
  TOLERANCIA
  BOOLEAN
}

model PlanificacionOTCaptura {
  id                  Int             @id @default(autoincrement())
  planificacion_ot_id Int
  campo_key           String          @db.VarChar(100)
  tipo_captura        TipoCaptura
  valor_numero        Decimal?        @db.Decimal(15, 4)
  valor_texto         String?
  valor_booleano      Boolean?
  valor_url           String?         @db.VarChar(500)
  unidad              String?         @db.VarChar(20)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @default(now()) @updatedAt
  planificacion_ot    PlanificacionOT @relation(fields: [planificacion_ot_id], references: [id], onDelete: Cascade)

  @@index([planificacion_ot_id])
  @@index([campo_key])
  @@map("planificacion_ot_captura")
}

// Sesión de trabajo de un técnico sobre una tarea (PlanificacionOT). Cada vez
// que un técnico aprieta "Iniciar" se crea una fila con inicio=now y fin=null.
// Al pausar/finalizar se le pone fin=now. La duración real de la tarea es
// la suma de (fin - inicio) de todas sus sesiones cerradas. La regla de
// negocio es: solo puede haber UNA sesión abierta (fin=null) por técnico a
// la vez (no se enforza con FK, se valida en el endpoint).
model PlanificacionOTSesion {
  id                  Int             @id @default(autoincrement())
  planificacion_ot_id Int
  tecnico             String          @db.VarChar(100)
  inicio              DateTime        @db.Timestamp(6)
  fin                 DateTime?       @db.Timestamp(6)
  // motivo de cierre: "pausa" | "finalizado" | "cancelado". null = sesión abierta.
  cierre              String?         @db.VarChar(20)
  // comentario que dejó el técnico al cerrar ESTA sesión (pausa/fin). Para el historial.
  comentario          String?         @db.VarChar(1000)
  created_at          DateTime        @default(now())
  planificacion_ot    PlanificacionOT @relation(fields: [planificacion_ot_id], references: [id], onDelete: Cascade)

  @@index([planificacion_ot_id])
  @@index([tecnico])
  @@index([fin])
  @@map("planificacion_ot_sesion")
}

model Contrato {
