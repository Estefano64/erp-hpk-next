model Compra {
  id                     Int             @id @default(autoincrement())
  numero_po              String          @unique @db.VarChar(50)
  numero_req             String?         @db.VarChar(50)
  nombre                 String?         @db.VarChar(300)
  ot_id                  Int?
  proveedor_id           Int
  fecha_solicitud        DateTime        @default(now()) @db.Date
  fecha_entrega_esperada DateTime?       @db.Date
  fecha_entrega_real     DateTime?       @db.Date
  ubicacion_codigo       String?         @db.VarChar(10)
  status_oc_codigo       String?         @db.VarChar(20)
  subtotal               Decimal         @default(0) @db.Decimal(12, 2)
  descuento              Decimal         @default(0) @db.Decimal(12, 2)
  impuesto               Decimal         @default(0) @db.Decimal(12, 2)
  otros                  Decimal         @default(0) @db.Decimal(12, 2)
  total                  Decimal         @default(0) @db.Decimal(12, 2)
  moneda_codigo          String?         @db.VarChar(10)
  nro_factura            String?         @db.VarChar(100)
  nro_guia               String?         @db.VarChar(100)
  // Tipo de pago acordado con el proveedor.
  //   CONTADO        → pago al recibir / sin plazo
  //   CREDITO        → pago a N días (ver dias_credito para el plazo)
  //   TRANSFERENCIA  → transferencia bancaria
  // Si se quiere agregar otra opción, alcanza con sumarla en la UI: el campo
  // es VARCHAR (no enum) así que no requiere migración.
  tipo_pago              String?         @db.VarChar(30)
  // Plazo en días cuando `tipo_pago = CREDITO`. Para CONTADO y TRANSFERENCIA
  // se guarda null o 0.
  dias_credito           Int?
  // Adjunto de guía de remisión en R2.
  guia_key               String?         @db.VarChar(500)
  guia_nombre            String?         @db.VarChar(300)
  guia_mime              String?         @db.VarChar(100)
  guia_tamano            Int?
  guia_fecha_subida      DateTime?
  // Adjunto de factura en R2.
  factura_key            String?         @db.VarChar(500)
  factura_nombre         String?         @db.VarChar(300)
  factura_mime           String?         @db.VarChar(100)
  factura_tamano         Int?
  factura_fecha_subida   DateTime?
  observaciones          String?
  usuario_solicita       String          @db.VarChar(100)
  usuario_aprueba        String?         @db.VarChar(100)
  // Comentario / recomendación que dejó el aprobador al aceptar la OC. Opcional.
  // Se persiste en el momento de aceptar (espejo del que va a OTHistorial)
  // para poder mostrarlo en la UI sin parsear el JSON del historial.
  comentario_aprobacion  String?         @db.VarChar(500)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  ubicacion              Ubicacion?      @relation(fields: [ubicacion_codigo], references: [codigo])
  orden_trabajo          OrdenTrabajo?   @relation(fields: [ot_id], references: [id], onDelete: Restrict)
  proveedor              Proveedor       @relation(fields: [proveedor_id], references: [id])
  status_oc              StatusOC?       @relation(fields: [status_oc_codigo], references: [codigo])
  moneda                 Moneda?         @relation(fields: [moneda_codigo], references: [codigo])
  detalles               CompraDetalle[]
  ot_repuestos           OTRepuesto[]

  @@index([numero_po])
  @@index([status_oc_codigo])
  @@index([ot_id])
  @@map("compras")
}

model CompraDetalle {
  id                   Int       @id @default(autoincrement())
