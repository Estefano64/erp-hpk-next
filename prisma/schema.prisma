  material_id          Int
  cantidad             Decimal   @db.Decimal(12, 4)
  cantidad_en_transito Decimal?  @default(0) @db.Decimal(12, 4)
  cantidad_recibida    Decimal?  @default(0) @db.Decimal(12, 4)
