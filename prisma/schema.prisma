generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Planta {
  planta_id                Int                   @id @default(autoincrement())
  codigo                   String                @unique @db.VarChar(10)
  nombre                   String                @db.VarChar(100)
  direccion                String?               @db.VarChar(200)
  activo                   Boolean               @default(true)
  areas                    Area[]
  equipos                  Equipo[]
  materiales               Material[]
  ordenes_trabajo_internas OrdenTrabajoInterna[]

  @@map("planta")
}

model Usuario {
  id             Int      @id @default(autoincrement())
  codigoEmpleado String   @unique @map("codigo_empleado") @db.VarChar(20)
  email          String?  @unique @db.VarChar(100)
  dni            String?  @unique @db.VarChar(20)
  password       String   @db.VarChar(255)
  nombre         String   @db.VarChar(100)
  // Roles del usuario. Multi-rol: una cuenta puede tener varios. Por ejemplo
  // un jefe que también es operario lleva ["admin", "tecnico", "evaluador"].
  // Roles bien definidos hoy:
  //   admin, viewer, tecnico, evaluador, aprobador_evaluacion, aprobador_requerimiento.
  // Roles "placeholder" (el admin los puede asignar pero su efecto en sidebar
  // y accesos se define en una fase posterior): planner, supervisor,
  // logistica, mantenimiento, contabilidad.
  roles          String[] @default([])
  activo         Boolean  @default(true)
  // Vínculo opcional con un Trabajador. No es obligatorio: hay cuentas de
  // sistema (admin/facturación/ventas) que no son trabajadores físicos del
  // taller. Cuando existe, permite mostrar la cuenta del trabajador desde la
  // pantalla de Trabajadores y filtrar tareas por trabajador en el panel
  // personal del rol "tecnico".
  trabajadorId   Int?     @unique @map("trabajador_id")
  trabajador     Trabajador? @relation(fields: [trabajadorId], references: [trabajador_id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("usuarios")
}

model Area {
  area_id       Int          @id @default(autoincrement())
  codigo        String       @unique @db.VarChar(10)
  nombre        String       @db.VarChar(100)
  planta_codigo String?      @db.VarChar(10)
  activo        Boolean      @default(true)
  planta        Planta?      @relation(fields: [planta_codigo], references: [codigo])
  equipos       Equipo[]
  estrategias   Estrategia[]
  materiales    Material[]
  sub_areas     SubArea[]

  @@map("area")
}

model SubArea {
  sub_area_id Int      @id @default(autoincrement())
  codigo      String   @unique @db.VarChar(10)
  nombre      String   @db.VarChar(100)
  area_codigo String   @db.VarChar(10)
  activo      Boolean  @default(true)
  equipos     Equipo[]
  area        Area     @relation(fields: [area_codigo], references: [codigo])

  @@map("sub_area")
}

model UnidadMedida {
  unidad_medida_id Int          @id @default(autoincrement())
