model Material {
  material_id           Int                    @id @default(autoincrement())
  codigo                String                 @unique @db.VarChar(50)
  descripcion_compuesta String?
  descripcion           String
  planta_codigo         String                 @db.VarChar(10)
  area_codigo           String                 @db.VarChar(10)
  categoria_codigo      String                 @db.VarChar(10)
  clasificacion_codigo  String                 @db.VarChar(10)
  punto_reposicion      Decimal?               @db.Decimal(10, 2)
  stock_maximo          Decimal?               @db.Decimal(10, 2)
  unidad_medida_codigo  String                 @db.VarChar(10)
  plazo_entrega         Int?
  precio                Decimal?               @db.Decimal(15, 4)
  moneda_codigo         String?                @db.VarChar(10)
  fabricante_codigo     String?                @db.VarChar(20)
  np                    String?                @db.VarChar(100)
  modelo                String?                @db.VarChar(100)
  caja                  String?                @db.VarChar(50)
  stock_actual          Decimal?               @default(0) @db.Decimal(10, 2)
  ubicacion             String?                @db.VarChar(50)
  // Costo promedio ponderado (PPP): se recalcula en cada ENTRADA contra OC
  // como (stock_actual × costo_promedio + cantidad_recibida × precio_oc) /
  // (stock_actual + cantidad_recibida). Es lo que se usa al hacer una SALIDA
  // (consumir-de-almacen) para registrar el costo en el MovimientoInventario
  // y, vía ese movimiento, acumular costos en la OT. Si las monedas de las
  // OCs entrantes difieren, se conserva la moneda del último ingreso.
  costo_promedio        Decimal?               @db.Decimal(15, 4)
  costo_promedio_moneda String?                @db.VarChar(10)
  activo                Boolean?               @default(true)
  created_at            DateTime?              @default(now())
  updated_at            DateTime?              @default(now()) @updatedAt
  compra_detalles       CompraDetalle[]
  area                  Area                   @relation(fields: [area_codigo], references: [codigo])
  categoria             Categoria              @relation(fields: [categoria_codigo], references: [codigo])
  clasificacion         Clasificacion          @relation(fields: [clasificacion_codigo], references: [codigo])
  fabricante            Fabricante?            @relation(fields: [fabricante_codigo], references: [codigo])
  moneda                Moneda?                @relation(fields: [moneda_codigo], references: [codigo])
  planta                Planta                 @relation(fields: [planta_codigo], references: [codigo])
  unidad_medida         UnidadMedida           @relation(fields: [unidad_medida_codigo], references: [codigo])
  ot_repuestos          OTRepuesto[]
  tareas                Tarea[]
  movimientos           MovimientoInventario[]
  cotizaciones          CotizacionProveedor[]

  @@map("material")
}

