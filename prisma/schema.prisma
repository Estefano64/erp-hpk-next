// ── Orden de Trabajo Interna (mantenimiento del taller HP&K) ──────
// Diferente a OrdenTrabajo (externa): no tiene cliente, no apunta a cilindros
// reparables del cliente, sino a Equipos del taller propio. Fuente: Excel
// "10. Ots internas.xlsx". Fase D2.1: schema + migración (sin API ni UI).
model OrdenTrabajoInterna {
  id                        Int                @id @default(autoincrement())
  // Código de la OT interna. Formato visual: "OI" + corr(4) + yy(2)
  // (ej. OI000126 = correlativo 1, año 2026). En BD se almacena como Int en
  // formato NNNNYY (igual que la OT externa) — la `formatOtInternaCodigo`
  // construye el código visible. Per-año, per-tipo (interna) — el correlativo
  // arranca en 1 cada año nuevo.
  ot                        Int?
  // Año (2 dígitos) derivado de `ot` (ot % 100). Denormalizado para filtrar
  // por año sin módulo en el where.
  anio                      Int?
  // Soft-delete (desactivar): false = anulada. Se oculta de los listados; los
  // datos se conservan y es reversible. El correlativo ignora las inactivas,
  // por lo que el número de una OT desactivada queda libre para reasignar
  // (mismo comportamiento que las externas tras la migración a Int).
  activo                    Boolean            @default(true)
  planta_codigo             String?            @db.VarChar(10)
  equipo_codigo             String?            @db.VarChar(50)
  tipo_ot_interna_codigo    String?            @db.VarChar(20)
  descripcion               String?
  prioridad_atencion_codigo String?            @db.VarChar(10)
  usuario_crea              String?            @db.VarChar(100)
  fecha_creacion            DateTime?          @default(now()) @db.Timestamp(3)
  fecha_inicio_plan         DateTime?          @db.Timestamp(3)
  fecha_fin_plan            DateTime?          @db.Timestamp(3)
  // Semana ISO en formato YYYY-Www (ej "2026W18"). Conecta con planificacion_ot.semana_plan.
  semana_revision           String?            @db.VarChar(10)
  fecha_inicio_real         DateTime?          @db.Timestamp(3)
  fecha_fin_real            DateTime?          @db.Timestamp(3)
  fecha_cierre              DateTime?          @db.Timestamp(3)
  estrategia_id             Int?
  // task_list es texto libre por ahora (referencia a tareas de Toño). FK a Tarea[] en fase futura.
  task_list                 String?
  user_status_codigo        String?            @db.VarChar(20)
  ot_status_codigo          String?            @db.VarChar(30)
  recursos_status_codigo    String?            @db.VarChar(30)
  // Área del taller a la que se asigna la OT interna. Código jerárquico tipo
  // "1.3.4" (Mantenimiento → Infraestructura). El mapeo código → label vive en
  // src/lib/areas-taller.ts (es un catálogo hardcoded, no FK). Reemplaza el
  // uso de equipo_codigo para OTs internas; equipo_codigo queda como legacy.
  area_taller               String?            @db.VarChar(50)
  // Operario asignado para ejecutar la OT (texto libre — guarda el nombre).
  asignado_a                String?            @db.VarChar(150)
  // Comentarios libres sobre la OT (instrucciones, contexto adicional).
  comentarios               String?
  version                   Int                @default(1)
  estrategia                Estrategia?        @relation(fields: [estrategia_id], references: [estrategia_id])
  equipo                    Equipo?            @relation(fields: [equipo_codigo], references: [codigo])
  ot_status                 OtStatus?          @relation("InternaOtStatus", fields: [ot_status_codigo], references: [codigo])
  planta                    Planta?            @relation(fields: [planta_codigo], references: [codigo])
  prioridad_atencion        PrioridadAtencion? @relation("InternaPrioridadAtencion", fields: [prioridad_atencion_codigo], references: [codigo])
  recursos_status           RecursosStatus?    @relation("InternaRecursosStatus", fields: [recursos_status_codigo], references: [codigo])
  tipo_ot_interna           TipoOTInterna?     @relation(fields: [tipo_ot_interna_codigo], references: [codigo])
  user_status               UserStatus?        @relation(fields: [user_status_codigo], references: [codigo])
  // Adjuntos, historial y requerimientos — polymórficos con OT externa.
  adjuntos                  OtAdjunto[]
  historial                 OTHistorial[]
  repuestos                 OTRepuesto[]

  @@index([equipo_codigo])
  @@index([tipo_ot_interna_codigo])
  @@index([ot_status_codigo])
  @@index([anio])
  @@map("orden_trabajo_interna")
}

// OtAdjunto admite adjuntos tanto de OT externa como de OT interna. Uno y solo
