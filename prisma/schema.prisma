  codigo_reparacion CodigoReparacion? @relation(fields: [cod_rep_id], references: [cod_rep_id])

  @@index([cliente_id])
  @@index([codigo])
  @@index([cod_rep_id])
  @@index([cliente_id, cod_rep_id])
  @@map("contrato")
}

model EvaluacionTecnica {
  id                       Int          @id @default(autoincrement())
  ot_id                    Int
  modelo_evaluacion        String       @db.VarChar(50)
  sistema_medicion         String       @default("Metrico") @db.VarChar(10)
  fecha_evaluacion         DateTime?    @db.Date
  evaluado_por             String?      @db.VarChar(150)
  // Supervisor que valida la evaluación al pie del informe (distinto de
  // `revisado_por` que se llena en el flujo de aprobación posterior).
  supervisor               String?      @db.VarChar(150)
  datos_formulario         Json         @default("{}")
  resultado_general        String?
  recomendaciones_general  String?
  // Adjunto del informe técnico en R2.
  informe_key              String?      @db.VarChar(500)
  informe_nombre           String?      @db.VarChar(300)
  informe_mime             String?      @db.VarChar(100)
  informe_tamano           Int?
  informe_fecha_subida     DateTime?
  estado                   String       @default("BORRADOR") @db.VarChar(25)
  revisado_por             String?      @db.VarChar(150)
  fecha_revision           DateTime?
  comentarios_revision     String?
  solicitado_revision_por  String?      @db.VarChar(150)
  fecha_solicitud_revision DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  orden_trabajo            OrdenTrabajo @relation(fields: [ot_id], references: [id], onDelete: Cascade)

  @@index([ot_id])
  @@index([estado])
  @@map("evaluaciones_tecnicas")
}


// ── Tickets — bugs, mejoras, preguntas reportadas por usuarios ──
// No vinculado a OT — es un canal lateral para issues del ERP mismo.
// Captura opcional en R2 bajo namespace `tickets/`.
model Ticket {
  id                Int      @id @default(autoincrement())
  descripcion       String
  // Estados: ABIERTO → EN_PROCESO → RESUELTO → CERRADO (lineal).
  estado            String   @default("ABIERTO") @db.VarChar(20)
  captura_key       String?  @db.VarChar(500)
  captura_nombre    String?  @db.VarChar(300)
  captura_mime      String?  @db.VarChar(100)
  captura_tamano    Int?
  creado_por        String   @db.VarChar(100)
  asignado_a        String?  @db.VarChar(100)
  notas_resolucion  String?
  resuelto_por      String?  @db.VarChar(100)
  fecha_resolucion  DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([estado])
  @@index([creado_por])
  @@index([created_at])
  @@map("ticket")
}

// Lock pesimista de edición. Una sola fila por (resource_type, resource_id):
// si existe y el heartbeat es reciente, otro usuario no puede entrar a editar.
// TTL manejado por el endpoint /api/locks: si el último heartbeat es más viejo
// que el TTL, la fila se considera "muerta" y otro usuario puede sobreescribirla.
model EditLock {
  resource_type   String   @db.VarChar(40)
  resource_id     Int
  usuario         String   @db.VarChar(120)
  acquired_at     DateTime @default(now())
  last_heartbeat  DateTime @default(now())

  @@id([resource_type, resource_id])
  @@index([last_heartbeat])
  @@map("edit_lock")
}
