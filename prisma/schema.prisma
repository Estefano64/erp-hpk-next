  orden_trabajo             OrdenTrabajo?        @relation(fields: [ot_id], references: [id], onDelete: Cascade)
  orden_trabajo_interna     OrdenTrabajoInterna? @relation(fields: [orden_trabajo_interna_id], references: [id], onDelete: Cascade)

