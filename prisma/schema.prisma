  tamano                    Int
  fecha_subida              DateTime             @default(now())
  usuario_sube              String?              @db.VarChar(100)
  orden_trabajo             OrdenTrabajo?        @relation(fields: [orden_trabajo_id], references: [id], onDelete: Cascade)
  orden_trabajo_interna     OrdenTrabajoInterna? @relation(fields: [orden_trabajo_interna_id], references: [id], onDelete: Cascade)
  etapa                     OtEtapa              @relation(fields: [etapa_codigo], references: [codigo], onDelete: Restrict)

  @@index([orden_trabajo_id])
  @@index([orden_trabajo_interna_id])
  @@map("ot_adjunto")
}

model Proveedor {
