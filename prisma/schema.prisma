model Material {
  material_id           Int                    @id @default(autoincrement())
  codigo                String                 @unique @db.VarChar(50)
  descripcion_compuesta String?
  descripcion           String
  planta_codigo         String                 @db.VarChar(10)
  area_codigo           String                 @db.VarChar(10)
  categoria_codigo      String                 @db.VarChar(10)
  clasificacion_codigo  String                 @db.VarChar(10)
  punto_reposicion      Decimal?               @db.Decimal(10, 2)
  stock_maximo          Decimal?               @db.Decimal(10, 2)
  unidad_medida_codigo  String                 @db.VarChar(10)
  plazo_entrega         Int?
  precio                Decimal?               @db.Decimal(15, 4)
  moneda_codigo         String?                @db.VarChar(10)
  fabricante_codigo     String?                @db.VarChar(20)
  np                    String?                @db.VarChar(100)
  modelo                String?                @db.VarChar(100)
  caja                  String?                @db.VarChar(50)
  stock_actual          Decimal?               @default(0) @db.Decimal(10, 2)
  ubicacion             String?                @db.VarChar(50)
  activo                Boolean?               @default(true)
  created_at            DateTime?              @default(now())
  updated_at            DateTime?              @default(now()) @updatedAt
  compra_detalles       CompraDetalle[]
  area                  Area                   @relation(fields: [area_codigo], references: [codigo])
  categoria             Categoria              @relation(fields: [categoria_codigo], references: [codigo])
  clasificacion         Clasificacion          @relation(fields: [clasificacion_codigo], references: [codigo])
  fabricante            Fabricante?            @relation(fields: [fabricante_codigo], references: [codigo])
  moneda                Moneda?                @relation(fields: [moneda_codigo], references: [codigo])
  planta                Planta                 @relation(fields: [planta_codigo], references: [codigo])
  unidad_medida         UnidadMedida           @relation(fields: [unidad_medida_codigo], references: [codigo])
  ot_repuestos          OTRepuesto[]
  tareas                Tarea[]
  movimientos           MovimientoInventario[]

  @@map("material")
}

model Equipo {
  equipo_id            Int           @id @default(autoincrement())
  codigo               String        @unique @db.VarChar(50)
  descripcion          String
  status_codigo        String        @db.VarChar(10)
  area_codigo          String        @db.VarChar(10)
  sub_area_codigo      String?       @db.VarChar(10)
  tipo_codigo          String        @db.VarChar(10)
  fecha_inicio         DateTime?     @db.Date
  fecha_fabricacion    DateTime?     @db.Date
  fabricante_codigo    String?       @db.VarChar(20)
  modelo               String?       @db.VarChar(100)
  numero_serie         String?       @db.VarChar(100)
  numero_parte         String?       @db.VarChar(100)
  capacidad            String?       @db.VarChar(50)
  unidad_medida_codigo String?       @db.VarChar(10)
  observaciones        String?
  planta_codigo        String        @db.VarChar(10)
  criticidad_codigo    String?       @db.VarChar(10)
  cantidad             Int           @default(1)
  usuario_responsable  String?       @db.VarChar(100)
  moneda_codigo        String?       @db.VarChar(10)
  precio               Decimal?      @db.Decimal(12, 2)
  ubicacion_codigo     String?       @db.VarChar(10)
  activo               Boolean       @default(true)
  usuario_crea         String?       @db.VarChar(100)
  usuario_actualiza    String?       @db.VarChar(100)
  created_at           DateTime      @default(now())
  updated_at           DateTime      @default(now()) @updatedAt
  area                 Area          @relation(fields: [area_codigo], references: [codigo])
  criticidad           Criticidad?   @relation(fields: [criticidad_codigo], references: [codigo])
  fabricante           Fabricante?   @relation(fields: [fabricante_codigo], references: [codigo])
  moneda               Moneda?       @relation(fields: [moneda_codigo], references: [codigo])
  planta               Planta        @relation(fields: [planta_codigo], references: [codigo])
  status               StatusEquipo  @relation(fields: [status_codigo], references: [codigo])
  sub_area             SubArea?      @relation(fields: [sub_area_codigo], references: [codigo])
  tipo                 TipoEquipo    @relation(fields: [tipo_codigo], references: [codigo])
  ubicacion            Ubicacion?    @relation(fields: [ubicacion_codigo], references: [codigo])
  unidad_medida        UnidadMedida? @relation(fields: [unidad_medida_codigo], references: [codigo])
  estrategias          Estrategia[]

  @@map("equipo")
}

model Estrategia {
  estrategia_id           Int                    @id @default(autoincrement())
  codigo                  String                 @unique @db.VarChar(50)
  area_codigo             String                 @db.VarChar(10)
  equipo_codigo           String?                @db.VarChar(50)
  conjunto_codigo         String?                @db.VarChar(20)
  actividad_codigo        String                 @db.VarChar(50)
  frecuencia              Int
  unidad_medida_codigo    String                 @db.VarChar(10)
  descripcion             String
  tipo_estrategia_codigo  String                 @db.VarChar(10)
  status_codigo           String                 @db.VarChar(10)
  fecha_ultima_ejecucion  DateTime?              @db.Date
  fecha_proxima_ejecucion DateTime?              @db.Date
  created_at              DateTime               @default(now())
  updated_at              DateTime               @default(now()) @updatedAt
  area                    Area                   @relation(fields: [area_codigo], references: [codigo])
  equipo                  Equipo?                @relation(fields: [equipo_codigo], references: [codigo])
  conjunto                ConjuntoMantenimiento? @relation(fields: [conjunto_codigo], references: [codigo])
  status                  StatusEstrategia       @relation(fields: [status_codigo], references: [codigo])
  tipo                    TipoEstrategia         @relation(fields: [tipo_estrategia_codigo], references: [codigo])
  unidad_medida           UnidadMedida           @relation(fields: [unidad_medida_codigo], references: [codigo])
  tareas                  Tarea[]

  @@index([equipo_codigo])
  @@index([conjunto_codigo])
  @@map("estrategia")
}

model ConfiguracionCotizacion {
